\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Theorem~\ref {thm:existence}, visually. Anomaly-neutral non-negative additions realize both signs of each tadpole axis (blue arrows, labeled by the number of multiplets --- the Farkas certificates), so the cone they generate is the whole plane $\mathbb  {R}^2$ (shaded). The origin is interior; hence the base residual $-\Theta _{\rm  base}=(-126,36)$ (star) --- and any other --- is cancellable by adding anomaly-neutral matter.}}{12}{figure.caption.11}\protected@file@percent }
\newlabel{fig:cone}{{6}{12}{Theorem~\ref {thm:existence}, visually. Anomaly-neutral non-negative additions realize both signs of each tadpole axis (blue arrows, labeled by the number of multiplets --- the Farkas certificates), so the cone they generate is the whole plane $\mathbb {R}^2$ (shaded). The origin is interior; hence the base residual $-\Theta _{\rm base}=(-126,36)$ (star) --- and any other --- is cancellable by adding anomaly-neutral matter}{figure.caption.11}{}}

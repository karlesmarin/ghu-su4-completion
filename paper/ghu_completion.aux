\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces The journey of this paper. We ask three questions in turn --- does the representation contain the Standard-Model quarks, is the resulting theory consistent, and is it physically viable --- each a stricter test than the last. The embedding and the consistency conditions are settled exactly (the localized anomalies machine-checked in Lean); the viability verdict, gated by the boundary-mass filter, is left open.}}{3}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:roadmap}{{1}{3}{The journey of this paper. We ask three questions in turn --- does the representation contain the Standard-Model quarks, is the resulting theory consistent, and is it physically viable --- each a stricter test than the last. The embedding and the consistency conditions are settled exactly (the localized anomalies machine-checked in Lean); the viability verdict, gated by the boundary-mass filter, is left open}{figure.caption.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces What each analysis establishes for the fermion sector of this class of six-dimensional orbifold models. AHMN~\cite  {AHMN} supply the gauge and two-Higgs sector we build on; systematic classifications treat bulk and localized anomalies; the present work adds the localized tadpole, an exact integer completion, and a Lean-checked fragment, imposing all of them together. Checkmarks indicate that the condition is treated for a concrete quark completion, not merely in principle.}}{3}{table.caption.3}\protected@file@percent }
\newlabel{tab:compare}{{1}{3}{What each analysis establishes for the fermion sector of this class of six-dimensional orbifold models. AHMN~\cite {AHMN} supply the gauge and two-Higgs sector we build on; systematic classifications treat bulk and localized anomalies; the present work adds the localized tadpole, an exact integer completion, and a Lean-checked fragment, imposing all of them together. Checkmarks indicate that the condition is treated for a concrete quark completion, not merely in principle}{table.caption.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Standard-Model quark content of $(3,\mathbf  {60})$ under the hypercharge \eqref  {eq:Y}, verified exactly. $Q_L$ occurs with multiplicity two --- one physical, one exotic --- a fact that returns in \S  \ref {sec:n7}.}}{4}{table.caption.4}\protected@file@percent }
\newlabel{tab:smcontent}{{2}{4}{Standard-Model quark content of $(3,\mathbf {60})$ under the hypercharge \eqref {eq:Y}, verified exactly. $Q_L$ occurs with multiplicity two --- one physical, one exotic --- a fact that returns in \S \ref {sec:n7}}{table.caption.4}{}}
